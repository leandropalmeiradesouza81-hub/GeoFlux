# ========================
# GeoFlux Backend Config
# ========================

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geoflux?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Bee Maps API (Hivemapper)
BEEMAPS_API_KEY=your-beemaps-api-key
BEEMAPS_API_URL=https://api.trybeekeeper.ai/v1

# Solana
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
SOLANA_WALLET_PRIVATE_KEY=your-wallet-private-key

# Jupiter API
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Storage (S3 compatible)
STORAGE_ENDPOINT=
STORAGE_BUCKET=geoflux-frames
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# HONEY Token Mint (Solana)
HONEY_TOKEN_MINT=4vMsoUT2BWatFweudnQM1xedRLfJgJ7hswhcpz4xgBTy

# Driver Reward
DRIVER_REWARD_PER_KM=0.10
